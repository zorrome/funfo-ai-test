#
# Funfo AI Store 环境变量示例（不会被实际加载，仅作为参考）
# 请复制为 `.env` 后按需填写真实值，本文件可以安全提交到 git。
#

# 宿主机上 openclaw / AI 工作区的根目录
# 例如：/Users/river/work/funfo/funfoai
HOST_PROJECT_ROOT=/absolute/path/to/your/openclaw_workspace

# 宿主机 Docker daemon 的 unix socket 路径
# Mac / Linux 一般为 /var/run/docker.sock
DOCKER_SOCK_PATH=/var/run/docker.sock

# 应用空闲自动回收配置
APP_IDLE_MINUTES=30
APP_IDLE_CHECK_MS=300000

# 运行时访问模式：
# - container：平台跑在 Docker 内（推荐当前用法），健康检查优先用容器 IP:3001
# - host：平台直接跑在宿主机，健康检查优先用 127.0.0.1:hostPort
RUNTIME_ACCESS_MODE=container

# 浏览器冒烟验证（发布前用无头浏览器跑一次 E2E）
# - 默认关闭（container 环境通常没有内置 Chrome）
# - 需要在 CI 或带浏览器的环境里启用时，将此值设为 0 并确保安装 Chrome/Chromium
DISABLE_BROWSER_SMOKE=1

# 调用外部 AI 服务（openclaw 或兼容接口）
OPENCLAW_URL=http://host.docker.internal:18789/v1/chat/completions
OPENCLAW_TOKEN=your-openclaw-token-here

# 平台默认 AI Provider（可选，用于自动写入 platform_ai_providers）
# 配置后，平台启动时如果表为空，会用这些值插入一条默认 Provider 记录。
# 注意：以下所有值的真实内容只放在 .env，不要提交到 git。
FUNFO_DEFAULT_PROVIDER_ID=openai-codex
FUNFO_DEFAULT_PROVIDER_LABEL=Codex OAuth
FUNFO_DEFAULT_PROVIDER_AUTH_TYPE=oauth
# 完整的 credentials_json 字符串（例如包含 access/refresh token 的 JSON）
FUNFO_DEFAULT_PROVIDER_CREDENTIALS_JSON={"oauth":{"access":"<ACCESS_TOKEN>","refresh":"<REFRESH_TOKEN>","expires":0,"accountId":"<ACCOUNT_ID>"}}
# 启用的模型列表（JSON 数组字符串）
FUNFO_DEFAULT_PROVIDER_MODELS_JSON=["gpt-5.4","gpt-5.3-codex","gpt-5.1-codex-mini"]
FUNFO_DEFAULT_PROVIDER_DEFAULT_MODEL_ID=gpt-5.4
# 额外元数据（可选，可为空，字符串形式的 JSON）
FUNFO_DEFAULT_PROVIDER_METADATA_JSON={"authMode":"oauth","accountId":"<ACCOUNT_ID>"}

