#
# Funfo AI Store 环境变量示例（不会被实际加载，仅作为参考）
# 请复制为 `.env` 后按需填写真实值，本文件可以安全提交到 git。
#

# 宿主机上 openclaw / AI 工作区的根目录
# 例如：/Users/river/.openclaw/workspace/projects/funfo/funfo_AI_Store
HOST_PROJECT_ROOT=/absolute/path/to/your/openclaw_workspace

# 宿主机 Docker daemon 的 unix socket 路径
# Mac / Linux 一般为 /var/run/docker.sock
DOCKER_SOCK_PATH=/var/run/docker.sock

# 应用空闲自动回收配置
APP_IDLE_MINUTES=30
APP_IDLE_CHECK_MS=300000

# 运行时访问模式：
# - container：平台跑在 Docker 内（推荐当前用法），健康检查优先用容器 IP:3001
# - host：平台直接跑在宿主机，健康检查优先用 127.0.0.1:hostPort
RUNTIME_ACCESS_MODE=container

# 浏览器冒烟验证（发布前用无头浏览器跑一次 E2E）
# - 默认关闭（container 环境通常没有内置 Chrome）
# - 需要在 CI 或带浏览器的环境里启用时，将此值设为 0 并确保安装 Chrome/Chromium
DISABLE_BROWSER_SMOKE=1

# 调用外部 AI 服务（openclaw 或兼容接口）
OPENCLAW_URL=http://host.docker.internal:18789/v1/chat/completions
OPENCLAW_TOKEN=your-openclaw-token-here

